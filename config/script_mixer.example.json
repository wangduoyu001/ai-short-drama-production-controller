{
  "discovery": {
    "tool_overrides": {},
    "model_overrides": {},
    "extra_search_roots": [],
    "max_scan_depth": 3,
    "max_entries_per_root": 5000
  },
  "media_scan": {
    "supported_extensions": [
      ".mp4",
      ".mov",
      ".mkv",
      ".avi",
      ".webm",
      ".m4v",
      ".mts",
      ".m2ts"
    ],
    "recursive": true,
    "follow_symlinks": false,
    "minimum_source_seconds": 0.7,
    "maximum_source_process_seconds": 40.0,
    "scene_detection_enabled": true,
    "scene_threshold": 0.34,
    "minimum_scene_seconds": 0.7,
    "maximum_scene_seconds": 6.0,
    "fallback_window_seconds": 3.0,
    "generate_thumbnails": true,
    "thumbnail_width": 360,
    "thumbnail_root": ".runtime/script_mixer/thumbnails",
    "proxy_generation_enabled": false,
    "proxy_root": ".runtime/script_mixer/proxies",
    "fingerprint_sample_bytes": 1048576
  },
  "local_models": {
    "auto_select_ollama_models": true,
    "ollama_base_url": "http://127.0.0.1:11434",
    "ollama_timeout_seconds": 90.0,
    "text_model": "",
    "vision_model": "",
    "embedding_model": "",
    "speech_model": ""
  },
  "audio": {
    "default_mode": "auto",
    "sample_rate": 48000,
    "channels": 2,
    "source_volume": 1.0,
    "mixed_source_volume": 0.22,
    "narration_volume": 1.0,
    "normalize_source": false,
    "normalize_narration": true,
    "narration_target_lufs": -16.0,
    "source_target_lufs": -18.0,
    "true_peak": -1.5,
    "loudness_range": 11.0,
    "ducking_threshold": 0.03,
    "ducking_ratio": 10.0,
    "ducking_attack_ms": 20.0,
    "ducking_release_ms": 300.0
  },
  "transcription": {
    "enabled": true,
    "auto_transcribe_narration": true,
    "allow_model_download": false,
    "language": "Chinese",
    "task": "transcribe",
    "word_timestamps": true,
    "device": "",
    "fp16": null,
    "timeout_seconds": 1800.0,
    "output_root": ".runtime/script_mixer/transcripts",
    "minimum_alignment_coverage": 0.55,
    "initial_prompt_max_chars": 500,
    "max_script_unit_chars": 26
  },
  "subtitles": {
    "enabled": true,
    "formats": ["srt", "ass"],
    "max_chars_per_line": 18,
    "max_lines": 2,
    "minimum_cue_seconds": 0.35,
    "maximum_cue_seconds": 8.0,
    "font_name": "Microsoft YaHei",
    "font_size": 64,
    "bold": 0,
    "outline": 3.0,
    "shadow": 1.0,
    "alignment": 2,
    "margin_left": 80,
    "margin_right": 80,
    "margin_vertical": 150,
    "burn_in_by_default": false
  },
  "mixing": {
    "target_width": 1080,
    "target_height": 1920,
    "fps": 30,
    "minimum_source_count": 8,
    "preferred_source_count": 12,
    "max_single_source_ratio": 0.15,
    "max_single_source_seconds": 4.0,
    "max_continuous_clip_seconds": 3.0,
    "minimum_clip_seconds": 0.7,
    "source_reuse_gap": 3,
    "low_match_threshold": 0.45,
    "allow_missing_media_files_during_planning": true
  },
  "integration": {
    "report_path": ".runtime/script_mixer/integration_report.json",
    "work_root": ".runtime/script_mixer/integration",
    "synthetic_render_enabled": true,
    "synthetic_render_seconds": 1.5,
    "command_timeout_seconds": 120.0,
    "minimum_free_space_bytes": 1073741824,
    "media_probe_limit": 100,
    "trial_duration_seconds": 30.0
  },
  "edit_package": {
    "output_dir_name": "jianying_package",
    "handle_before_seconds": 1.0,
    "handle_after_seconds": 1.0,
    "candidate_export_count": 3,
    "export_source_audio_stems": true,
    "export_narration_wav": true,
    "export_subtitles": true,
    "video_codec": "libx264",
    "video_preset": "medium",
    "video_crf": 18,
    "audio_codec": "pcm_s16le",
    "sample_rate": 48000,
    "channels": 2,
    "clean_stale_files": false,
    "create_jianying_draft": true,
    "require_jianying_draft": false,
    "jianying_draft_root": "",
    "jianying_draft_name_prefix": "AI粗剪"
  },
  "database_path": ".runtime/script_mixer/media.db",
  "discovery_report_path": ".runtime/script_mixer/discovery.json",
  "output_root": "outputs/script_mixer"
}
